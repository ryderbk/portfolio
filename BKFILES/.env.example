# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Get these from Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_id:web:your_web_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G_YOUR_MEASUREMENT_ID

# ============================================
# OPENAI CONFIGURATION
# ============================================
# Get from https://platform.openai.com/api-keys
# CRITICAL: Keep this secret! Never expose to frontend
OPENAI_API_KEY=sk-your_openai_key_here

# ============================================
# CLOUDINARY CONFIGURATION
# ============================================
# Get from https://cloudinary.com/console/settings/basic
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# GOOGLE GENERATIVE AI (OPTIONAL)
# ============================================
# Get from https://ai.google.dev
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_key_here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
