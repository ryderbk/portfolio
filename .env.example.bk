# ============================================
# FIREBASE CONFIGURATION (Vite Client)
# ============================================
# Get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id:web:your_web_id
VITE_FIREBASE_MEASUREMENT_ID=G_YOUR_MEASUREMENT_ID

# ============================================
# OPENAI CONFIGURATION (Backend Only)
# ============================================
# Get from https://platform.openai.com/api-keys
# CRITICAL: Keep this secret! Never expose to frontend
OPENAI_API_KEY=sk-your_openai_key_here

# ============================================
# CLOUDINARY CONFIGURATION (Backend Only)
# ============================================
# Get from https://cloudinary.com/console/settings/basic
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# APPLICATION CONFIGURATION
# ============================================
VITE_APP_URL=http://localhost:5173
